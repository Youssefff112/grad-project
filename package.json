  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
