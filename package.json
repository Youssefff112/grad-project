{
  "name": "app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear --port 8082",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "backend": "cd backend && npm run dev",
    "tunnel": "cd backend && npm run tunnel",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run check:backend-syntax",
    "check:backend-syntax": "npm run check-syntax --prefix backend"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@react-navigation/stack": "^7.9.2",
    "axios": "^1.7.7",
    "expo": "~54.0.34",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "^3.0.9",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-netinfo": "^1.1.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "^15.12.1",
