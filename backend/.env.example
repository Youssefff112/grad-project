# FitCore Backend — Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit your actual .env to version control.

# PostgreSQL connection (update credentials to match your local Postgres setup)
DATABASE_URL=postgres://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/postgres
# After the database is running: register users through the app (no demo seed data).

# JWT secrets — generate random strings for security
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

NODE_ENV=development

# Dev only: allow provider=demo payments to activate subscriptions (disabled in production)
ALLOW_DEMO_PAYMENTS=true

# Dev only: auto-alter schema on startup (set false to use migrations only)
DB_SYNC_ALTER=true

# Production: restrict Socket.IO CORS to your app origin
# FRONTEND_URL=https://your-app.example.com

# Email (set to true and provide SMTP credentials to enable password reset emails)
EMAIL_ENABLED=false
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=you@example.com
# EMAIL_PASS=yourpassword

PORT=5000

# Python FastAPI AI service (workout + meal plan generation, CV, chat). Node defaults to http://localhost:8000 if unset.
# Start from repo: cd ai-backend && uvicorn main:app --reload --port 8000
AI_SERVICE_URL=http://localhost:8000
