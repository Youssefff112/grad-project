# FitCore Backend — Environment Variables
# Copy this file to .env and fill in your local values.
# Never commit your actual .env to version control.

# PostgreSQL connection (update credentials to match your local Postgres setup)
DATABASE_URL=postgres://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/fitcore
# After the database is running: from this folder run `npm run seed` for demo users and coaches.

# JWT secrets — generate random strings for security
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

NODE_ENV=development

# Email (set to true and provide SMTP credentials to enable password reset emails)
EMAIL_ENABLED=false
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USER=you@example.com
# EMAIL_PASS=yourpassword

PORT=5000
